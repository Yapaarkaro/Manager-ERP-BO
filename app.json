{
  "expo": {
    "name": "Manager",
    "slug": "manager-erp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "manager",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.getmanager.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to location to show your current position on the map",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to location to show your current position on the map",
        "NSCameraUsageDescription": "This app needs camera access to scan product barcodes"
      }
    },
    "android": {
      "package": "com.exanite.manager",
      "versionCode": 1,
      "targetSdkVersion": 34,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBqLe3lHfzB5epezdgwdKDzkdFkECuUN1o"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "Manager",
      "shortName": "Manager",
      "description": "Complete business management for Indian businesses",
      "themeColor": "#2c5282",
      "backgroundColor": "#FFFFFF"
    },
    "plugins": [
      "./plugins/withAndroidxCorePin.js",
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Manager to use your location to show your position on the map."
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0ce92a3c-656f-4418-af1c-cbf860cc29d8"
      }
    },
    "owner": "getmanager"
  }
}
